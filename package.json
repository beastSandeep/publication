{
  "name": "publication",
  "version": "0.0.0",
  "description": "This is Publication's Private Server",
  "main": "server.js",
  "sourceType": "module",
  "scripts": {
    "debug": "ndb --env-file=.env server.js",
    "linux:prod": "NODE_ENV=production node --env-file=.env server.js",
    "linux:dev": "NODE_ENV=development node --env-file=.env server.js",
    "win:dev": "SET NODE_ENV=development&&SET TZ=Asia/Kolkata&&nodemon --env-file=.env server.js",
    "win:prod": "SET NODE_ENV=production&&nodemon server.js",
    "css:build": "postcss public/styles/tailwind.css -o public/styles/style.css",
    "css:watch": "postcss public/styles/tailwind.css -o public/styles/style.css --watch",
    "prod": "npm run css:build && npm run linux:prod",
    "dev": "start powershell -NoExit -Command \"npm run css:watch\" && npm run win:dev"
  },
  "author": "Sandeep Singh",
  "license": "ISC",
  "dependencies": {
    "autoprefixer": "~10.4.15",
    "bcryptjs": "~2.4.3",
    "compression": "~1.7.4",
    "cookie-parser": "~1.4.6",
    "cors": "~2.8.5",
    "express": "~4.18.2",
    "express-mongo-sanitize": "~2.2.0",
    "express-rate-limit": "~6.8.1",
    "helmet": "~7.0.0",
    "hpp": "~0.2.3",
    "html-to-text": "~9.0.5",
    "jsonwebtoken": "~9.0.1",
    "mongoose": "~7.4.1",
    "morgan": "~1.10.0",
    "nodemailer": "~6.9.4",
    "nodemon": "~3.0.1",
    "postcss": "~8.4.28",
    "postcss-cli": "~10.1.0",
    "pug": "~3.0.2",
    "request-ip": "^3.3.0",
    "sharp": "^0.32.5",
    "slugify": "~1.6.6",
    "stripe": "~13.3.0",
    "tailwindcss": "~3.3.3",
    "validator": "~13.9.0",
    "xss-clean": "~0.1.4"
  },
  "engines": {
    "node": "24.x"
  }
}
