mixin dropDown(name, links, w=12)
  button(class="group flex justify-between gap-1 items-center relative py-4 border-b-4 border-white hover:border-blue-300 hover:text-blue-300 transition-all") 
    p #{name}
    svg(class="fill-slate-700 group-hover:fill-blue-300 transition-all", width='12px', height='12px', viewBox='-6.5 0 32 32', version='1.1', xmlns='http://www.w3.org/2000/svg')
      path(d='M18.813 11.406l-7.906 9.906c-0.75 0.906-1.906 0.906-2.625 0l-7.906-9.906c-0.75-0.938-0.375-1.656 0.781-1.656h16.875c1.188 0 1.531 0.719 0.781 1.656z')
    div(class=`z-10 transition-all flex flex-col items-start gap-1 border border-slate-200 rounded shadow-md w-48 bg-white absolute top-full left-0 origin-top scale-y-0 group-focus:scale-y-100 group-hover:scale-y-100`, style=`width:${w}rem`)
      each linkObj in links
        a(href=`${linkObj.link}`, class="text-slate-700 text-start w-full transition-all hover:text-blue-400 px-2 py-2 hover:bg-slate-100") #{linkObj.name} 

mixin dropDown2(name, links, w=12)
  button(class="group flex justify-between gap-1 items-center relative hover:text-blue-300 transition-all") 
    p #{name}
    svg(class="fill-slate-100 group-hover:fill-blue-300 transition-all", width='12px', height='12px', viewBox='-6.5 0 32 32', version='1.1', xmlns='http://www.w3.org/2000/svg')
      path(d='M18.813 11.406l-7.906 9.906c-0.75 0.906-1.906 0.906-2.625 0l-7.906-9.906c-0.75-0.938-0.375-1.656 0.781-1.656h16.875c1.188 0 1.531 0.719 0.781 1.656z')
    div(class=`z-10 transition-all flex flex-col items-start gap-1 border border-slate-200 rounded shadow-md w-full bg-white absolute top-full left-0 origin-top scale-y-0 group-focus:scale-y-100 group-hover:scale-y-100`, style=`width:${w}rem`)
      each linkObj in links
        a(href=`${linkObj.link}`, class="text-slate-700 text-start w-full transition-all hover:text-blue-400 px-2 py-2 hover:bg-slate-100") #{linkObj.name}


script(src="/scripts/mobileNavBar.js", defer) 
aside#sideNavBar(class="absolute pt-4 px-2 block lg:hidden w-fit z-[60] top-0 left-0 bg-gray-800 h-screen border text-gray-50 border-slate-200 rounded shadow-md p-4 transition-all origin-left scale-x-0")
  div(class="flex flex-col gap-4")
    +dropDown2("ABOUT",[{name:"ABOUT THE JOURNAL", link:"/about"},{name:"PRIVACY STATEMENT", link:"/privacy"},{name:"ABOUT PUBLISHER", link:"/publisher"}])
    a(href="/editorial-team",class="hover:text-blue-300") EDITORIAL TEAM
    +dropDown2("REVIEW",[{name:"REVIEW POLICY", link:"/review-policy"}])
    a(href="/indexing",class="hover:text-blue-300") INDEXING
    +dropDown2("AUTHOR GUIDE",[{name:"SUBMISSIONS", link:"/submissions"},{name:"AUTHOR INSTRUCTIONS", link:"/author-instructions"},{name:"REFRENCE MANAGEMENT", link:"/reference-management"}, {name:"APPLY FOR EDITOR", link:"/apply-editor"}, {name:"AIM AND SCOPE", link:"/aim-and-scope"}], 15)
    +dropDown2("ARTICLES",[{name:"CURRENT", link:"/about"},{name:"ARCHIVE", link:"/about"}])
    a(href="/contact",class="hover:text-blue-300") CONTACT 






nav.px-8.flex.flex-wrap.justify-between.items-center.text-slate-600.font-semibold.text-sm.border-b.border-slate-200(role="navigation", aria-label="main navigation", id="navbar", class="sticky top-0 bg-white z-50 py-2 lg:py-0 gap-2 lg:gap-0")
  div.gap-4.hidden(class="lg:flex")
    +dropDown("ABOUT",[{name:"ABOUT THE JOURNAL", link:"/about"},{name:"PRIVACY STATEMENT", link:"/privacy"},{name:"ABOUT PUBLISHER", link:"/publisher"}])
    a(href="/editorial-team",class="py-4 border-b-4 border-white hover:border-blue-300 hover:text-blue-300 transition-all") EDITORIAL TEAM
    +dropDown("REVIEW",[{name:"REVIEW POLICY", link:"/review-policy"}])
    a(href="/indexing",class="py-4 border-b-4 border-white hover:border-blue-300 hover:text-blue-300 transition-all") INDEXING
    +dropDown("AUTHOR GUIDE",[{name:"SUBMISSIONS", link:"/submissions"},{name:"AUTHOR INSTRUCTIONS", link:"/author-instructions"},{name:"REFRENCE MANAGEMENT", link:"/reference-management"}, {name:"APPLY FOR EDITOR", link:"/apply-editor"}, {name:"AIM AND SCOPE", link:"/aim-and-scope"}],15)
    +dropDown("ARTICLES",[{name:"CURRENT", link:"/about"},{name:"ARCHIVE", link:"/about"}])

    a(href="/contact",class="py-4 border-b-4 border-white hover:border-blue-300 hover:text-blue-300 transition-all") CONTACT
  div(class="lg:hidden block")
    button#mobileMenuButton(class="flex items-center gap-2 py-3 group border hover:border-amber-500 px-3 rounded-xl transition-all h-fit", aria-label="Toggle navigation menu", aria-expanded="false", aria-controls="mobileMenu")
      svg(width='20px', height='20px', viewBox='0 0 24 24', fill='none', xmlns='http://www.w3.org/2000/svg')
        path(d='M3 12H21M3 6H21M3 18H21', class="transition-all stroke-amber-500 group-hover:stroke-blue-300", stroke-width='2', stroke-linecap='round', stroke-linejoin='round')
      p(class="text-sm text-slate-600 group-hover:text-blue-300 transition-all") MENU

  a(href="/search", role="search", class="flex justify-between items-center py-3 gap-2 group border hover:border-amber-500 px-3 rounded-xl transition-all h-fit")
    svg(width='20px', height='20px', viewBox='0 0 24 24', fill='none', xmlns='http://www.w3.org/2000/svg')
      path(d='M16.6725 16.6412L21 21M19 11C19 15.4183 15.4183 19 11 19C6.58172 19 3 15.4183 3 11C3 6.58172 6.58172 3 11 3C15.4183 3 19 6.58172 19 11Z', class="transition-all stroke-amber-500 group-hover:stroke-blue-300", stroke-width='2', stroke-linecap='round', stroke-linejoin='round')
    p(class="text-sm text-slate-600 group-hover:text-blue-300 transition-all") SEARCH