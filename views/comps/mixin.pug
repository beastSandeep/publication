mixin breadCrump(links)
  nav.flex.gap-2.text-sm.text-slate-500
    each linkObj, index in links
      if index != links.length - 1
        a(href=`${linkObj.link}`, class="hover:text-blue-300 transition-all") #{linkObj.name}
        p / 
      else
        p(class="select-none") #{linkObj.name}

mixin input(labelText, inputId, inputName, inputType="text", placeholder="", required=true, accept="*", multiple=true)
  div.flex-1(class="min-w-[250px]")
    label(for=inputId, class="block text-gray-700 mb-2 font-medium cursor-pointer") #{`${labelText} `}
      span.text-red-500 #{required ? "*" : ""}
    input(type=inputType, name=inputName, required=required, placeholder=placeholder, id=inputId, class="border border-gray-300 rounded-md py-2 px-4 w-full placeholder:font-light placeholder:text-base placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all", accept=accept, multiple=multiple)

mixin textArea(labelText, textAreaId, inputName, inputType="text", placeholder="", required=true)
  div.flex-1(class="min-w-[250px]")
    label(for=textAreaId, class="block text-gray-700 mb-2 font-medium cursor-pointer") #{`${labelText}${required ? " *" : ""}`}
    textarea(name=inputName, required=required, placeholder=placeholder, id=textAreaId, class="border border-gray-300 rounded-md py-2 px-4 w-full placeholder:font-light placeholder:text-base placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-color", rows="5")

mixin button(buttonText, classes="")
  button(type="submit", id="submit-btn",  class=`bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded transition-all ${classes}`) #{buttonText}