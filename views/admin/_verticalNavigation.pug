mixin chip(link,name)
  a(href=link, class=`flex items-center gap-4 px-3 py-2 rounded-md font-normal text-lg ${currentActivePage === name ? "text-blue-500 bg-blue-100" : "text-gray-500 hover:bg-blue-100"}`)
    if block
      block
    p.navigationName.hidden #{name}


//- all svg from https://heroicons.com/solid

main.px-4.flex.flex-col.justify-between.h-full(class="overflow-y-auto")
  //- Top
  section 
    //- logo + button
    section.bg-gray-100.px-2.py-2.flex.justify-center.items-center.gap-2
      div#logo.hidden LOGO
      button#toggleNavigation.bg-orange-400.text-white.rounded-full.origin-center.rotate-0.transition-all.duration-300.w-8.h-8.flex.justify-center.items-center
        svg(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6")
          path(stroke-linecap="round" stroke-linejoin="round" d="M16 7L21 12M21 12L16 17M21 12H3")
    
    //- tab links
    section.py-8.flex.flex-col.gap-3
